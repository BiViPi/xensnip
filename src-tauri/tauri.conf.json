{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XenSnip",
  "version": "0.1.1",
  "identifier": "com.bivipi.xensnip",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data: xensnip-asset:; font-src 'self' data:; connect-src 'self' ipc: tauri: https://cdn.jsdelivr.net; media-src 'self' blob:; worker-src blob:",
      "dangerousDisableAssetCspModification": ["xensnip-asset"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
